    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        emacs-pgtk \
        ripgrep \
        fd-find \
    && \
    dnf --assumeyes install \
        cmake \
        go \
        gopls \
        hunspell \
        hunspell-en-US \
        hunspell-fr \
        libtool \
        nodejs-bash-language-server \
        nodejs-npm \
        pandoc \
        shfmt \
        wl-clipboard \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
