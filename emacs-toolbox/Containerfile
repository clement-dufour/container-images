FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:ac02b961570dbe8db548a63feda343813cd2f0136bcc2c9a3f14be7ba783915f

RUN --mount=type=tmpfs,target=/var << 'EOF'
set -e -o nounset -o pipefail
set -x

dnf config-manager disable \
    fedora-cisco-openh264 \


dnf --assumeyes install \
    adw-gtk3-theme \
    flatpak-xdg-utils \


dnf --assumeyes install \
    emacs-pgtk \
    ripgrep \
    fd-find \


dnf --assumeyes install \
    cmake \
    go \
    gopls \
    hunspell \
    hunspell-en-US \
    hunspell-fr \
    libtool \
    nodejs-bash-language-server \
    nodejs-npm \
    pandoc \
    shfmt \
    wl-clipboard \


dnf clean all

ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
EOF
