FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:c8bf9e66edf441758940eb7814fa8621126e977d629224e33b58e98b8983c05b

RUN --mount=type=tmpfs,target=/var << 'EOF'
set -e -o nounset -o pipefail
set -x

dnf config-manager disable \
    fedora-cisco-openh264 \


dnf --assumeyes install \
    adw-gtk3-theme \
    flatpak-xdg-utils \


dnf --assumeyes install \
    emacs-pgtk \
    ripgrep \
    fd-find \


dnf --assumeyes install \
    cmake \
    go \
    gopls \
    hunspell \
    hunspell-en-US \
    hunspell-fr \
    libtool \
    nodejs-bash-language-server \
    nodejs-npm \
    pandoc \
    shfmt \
    wl-clipboard \


dnf clean all

ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
EOF
