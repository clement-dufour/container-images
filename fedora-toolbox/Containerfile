FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:3cf60d62ebd2c8ec4fe519871a7acfa7c070e6e328e572b00b9792f1b890adc6

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
