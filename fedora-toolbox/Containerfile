FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:f5f7f4ab4342801c037f572f750431ce39fc4c69f1017e493222bbbca0323e58

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
