FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:e9043b37ad3c5d59f94b2fffc298096553a69319b173ced93f5aa0de692ee512

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
