FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:6b6818e74c3c317d24cfa6f27dbc0c132d15507d85e3d8a6a8fb3c0afe2653e6

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
