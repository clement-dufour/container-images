FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:b17081bd45113cade235a83cbb392273f771cc6273a0e64ea9e3f0ede904a456

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
