FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:a659f78e367b59b47ccb7c9d1f41be1a4b4d9dea63541f760f922201faab24b9

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
