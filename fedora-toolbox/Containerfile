FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:79409346347d66647945b1d8030730b5a85273bb1cacd6b1f4bde3ca32c04200

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
