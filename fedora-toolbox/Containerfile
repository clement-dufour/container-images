FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:32fc665c4df3a7a462c5116eeccf8b22843e554fa089938ba3b4eee045616252

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
