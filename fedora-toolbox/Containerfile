FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:d324396eb4a788f8816c0d6e6dabad94ba5a7873580af6d70ff70e3f8a3461cf

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
