FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:9755d6f9fa33b62b74467ed53b98db891908b8aa8e24424b40918ac81d0d130e

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
