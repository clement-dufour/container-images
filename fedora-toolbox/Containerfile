FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:e8cf353ec9b124dbc7cc162a8fd5e87e30b96bc91a219b06f22314c61708a04f

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
