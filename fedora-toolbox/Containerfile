FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:f957cbe226b7eaf1b7c65cf7023a43fb60c8c57c99f678ce7ff67beab5a40fcc

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
