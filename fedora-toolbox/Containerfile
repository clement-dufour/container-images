FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:28608f37a7c4929ea2a6cb205e0899e02b8a70146ccc3290b8910898660cba00

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
