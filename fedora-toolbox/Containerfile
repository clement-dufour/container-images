FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:362afcbbe9046aa4130cff0cbe17ad905244804e42af59ce972b374dcb8d7904

RUN --mount=type=tmpfs,target=/var << 'EOF'
set -e -o nounset -o pipefail
set -x

dnf config-manager disable \
    fedora-cisco-openh264 \


dnf --assumeyes install \
    adw-gtk3-theme \
    flatpak-xdg-utils \


dnf --assumeyes install \
    emacs-pgtk \
    ripgrep \
    fd-find \


dnf --assumeyes install \
    fzf \
    mpv \
    stow \


dnf clean all

ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
EOF
