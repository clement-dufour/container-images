FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:48e1554cd5f8c28f54c771157dfcb2701f7c41439e4a1ad9814af1701256ea4a

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
