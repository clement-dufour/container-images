FROM registry.fedoraproject.org/fedora-toolbox:45@sha256:8ba43beccd768fd632530b22d44191c8f03aaf8414bd12bccec916770d20ccb0

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
