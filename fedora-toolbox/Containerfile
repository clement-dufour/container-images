FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:9fa5a029a88738b9020b38adc5bf997dfbdc34e2cb2a1499987af12b7038ca0d

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
