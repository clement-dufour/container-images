FROM registry.fedoraproject.org/fedora-toolbox:44@sha256:b15cff4013cbd7966119d043ec2a4609c93701c588182d54cba6035539c7bfa2

RUN \
    dnf config-manager disable \
        fedora-cisco-openh264 \
    && \
    dnf --assumeyes install \
        adw-gtk3-theme \
        flatpak-xdg-utils \
    && \
    dnf --assumeyes install \
        fzf \
        mpv \
        stow \
    && \
    dnf clean all && \
    ln -sf /usr/bin/flatpak-xdg-open /usr/bin/xdg-open
