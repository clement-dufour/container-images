{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "recreateWhen": "always",
  "packageRules": [
    {
      "matchPackageNames": [
        "registry.fedoraproject.org/fedora-toolbox"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true
    },
    {
      "matchPackageNames": [
        "registry.fedoraproject.org/fedora-toolbox"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    }
  ]
}
